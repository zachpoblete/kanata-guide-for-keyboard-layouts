;; Keymap Drawer visual: https://caksoylar.github.io/keymap-drawer?keymap_yaml=H4sIAAAAAAACA4XNzUrDQBTF8X2e4tDNbE6kSb_HB_AhSiiTWG3aSaYmE2ssfXdvHUQQZO7iLg4_-FszusFrXCtn-50_DE3Z71rnja9dq5HfL_wbEmvGfdfrBFB52rkLnoy19dCo-wSk2JaEJZ6JingnjsQL4YiBUFTFD2uJjvBET7wSI3EgDLEn6iKpXFO670yK61ljOyWyaUGcND4kIMuffnH7xZngLOC3KM4F5wE3UTwTPAv4EsVzwfOAP6N4IXgR8CmKl4KXAZ-jeCV4FfBETaJ8LXwd-GMUbwRvAn74B38BEXeGQV8CAAA%3D
;; This Kanata config maps the bottom row of Gallium to vertical
;; combos with the top and home rows.

(defvar
  chord-timeout 50
)

(defsrc
   q  w  e  r  t    y  u  i  o  p
   a  s  d  f  g    h  j  k  l  ;
)

(deflayer gallium
  @b @l @d @c @v   @j @f @o @u @,
  @n @r @t @s @g   @y @h @a @e @i
)

(defalias
  n (chord combos n)
  r (chord combos r)
  t (chord combos t)
  s (chord combos s)
  g (chord combos g)
  y (chord combos y)
  h (chord combos h)
  a (chord combos a)
  e (chord combos e)
  i (chord combos i)
  b (chord combos b)
  l (chord combos l)
  d (chord combos d)
  c (chord combos c)
  v (chord combos v)
  j (chord combos j)
  f (chord combos f)
  o (chord combos o)
  u (chord combos u)
  , (chord combos ,)
)

(defchords combos $chord-timeout
  (n) n
  (r) r
  (t) t
  (s) s
  (g) g
  (y) y
  (h) h
  (a) a
  (e) e
  (i) i
  (b) b
  (l) l
  (d) d
  (c) c
  (v) v
  (j) j
  (f) f
  (o) o
  (u) u
  (,) ,

  (n b) x
  (l r) q
  (d t) m
  (c s) w
  (v g) z
  (j y) k
  (f h) p
  (o a) '
  (u e) ;
  (, i) .
)
