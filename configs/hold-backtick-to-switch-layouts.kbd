;; This Kanata config remaps your keyboard to the Gallium layout and
;; makes holding the backtick ` key toggle between Gallium and QWERTY.

(defvar
  tap-time  200
  hold-time 200
)

(defsrc
  `
    q w e r t  y u i o p
    a s d f g  h j k l ; '
    z x c v b  n m , . /
)

(deflayer gallium
  (tap-hold $tap-time $hold-time ` (layer-switch qwerty))
    b l d c v  j f o u ,
    n r t s g  y h a e i /
    x q m w z  k p ' ; .
)

(deflayermap (qwerty)
  ` (tap-hold $tap-time $hold-time ` (layer-switch gallium))
  _ use-defsrc
)
