;; Original layout: https://valorance.net/night/images/night_rowstag.png

;; This Kanata config remaps your keyboard to the Night layout with
;; wide mod. For more information about wide mod, see:
;; https://colemakmods.github.io/ergonomic-mods/wide.html

(defsrc
  q w e r t    u i o p [
  a s d f g    j k l ; '
  z x c v b    m , . / rsft
       spc       ralt
)

(deflayer night-wide
  b f l k q    ' g o u .
  n s h t m    y c a e i
  x v j d z    p w ; / ,
        r        spc
)
