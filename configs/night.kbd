;; Official website: https://valorance.net/night/

;; This Kanata config remaps your keyboard to Night, a layout with a
;; thumb alpha key. For more information about thumb alpha, see:
;; https://layouts.wiki/guides/start/recommendations/#thumb-alpha

(defsrc
  q w e r t  y u i o p
  a s d f g  h j k l ;
  z x c v b  n m , . /
       lalt
)

(deflayer night
  b f l k q  p g o u .
  n s h t m  y c a e i
  x v j d z  ' w ; / ,
        r
)
